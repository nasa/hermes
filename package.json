{
    "name": "root",
    "version": "4.0.0",
    "private": true,
    "workspaces": [
        "src/cli",
        "src/internal",
        "src/modules/*",
        "src/extensions/*"
    ],
    "scripts": {
        "watch": "node build watch",
        "build": "node build build",
        "test": "jest",
        "coverage": "jest --coverage",
        "lint": "NODE_OPTIONS=\"--max-old-space-size=8192\" yarn eslint .",
        "ci:coverage": "jest --coverage --coverageReporters=cobertura",
        "clean": "sh -c 'cd src/extensions/${0} && yarn clean'",
        "protocol-fprime": "./out/protocolc -p fprime -o pkg/fprime/packet.go ./pkg/fprime/fprime.protocol",
        "protocol-ccsds": "./out/protocolc -p ccsds -o pkg/ccsds/packet.go ./pkg/ccsds/ccsds.protocol",
        "protocol": "yarn protocol-fprime && yarn protocol-ccsds",
        "proto-go-pb": "protoc -I=proto/pb --go_opt=paths=source_relative --go_out=pkg/pb proto/pb/*.proto",
        "proto-go-grpc": "protoc -I=proto/pb -Iproto/grpc --go_opt=paths=source_relative --go_out=pkg/grpc --go-grpc_opt=paths=source_relative --go-grpc_out=pkg/grpc proto/grpc/*.proto",
        "proto-go": "npm run proto-go-pb && npm run proto-go-grpc",
        "proto-js": "pbjs -t static-module -w commonjs -o src/modules/types/src/proto/index.js proto/pb/*.proto",
        "proto-ts": "pbjs -t static-module proto/pb/*.proto | pbts -o src/modules/types/src/proto/index.d.ts -",
        "proto-py": "cd lib/python && source venv/bin/activate && python -m grpc_tools.protoc --grpc_python_out=. ../../proto/grpc/hermes.proto --pyi_out=. -I ../../proto/pb/ -I ../../proto/grpc && python -m grpc_tools.protoc -I. --python_out=. --pyi_out=. ../../proto/pb/*.proto -I ../../proto/pb",
        "proto-ts-grpc": "yarn proto-loader-gen-types -I=proto/pb -I=proto/grpc --grpcLib=@grpc/grpc-js --outDir=src/modules/rpc/src/proto/hermes hermes.proto",
        "proto-json-grpc": "yarn pbjs -p=proto/pb -t json proto/grpc/hermes.proto -o src/modules/rpc/src/proto/hermes.json",
        "proto": "npm run proto-go && npm run proto-js && npm run proto-ts && npm run proto-ts-grpc && npm run proto-json-grpc && npm run proto-py",
        "leap-seconds": "curl https://data.iana.org/time-zones/data/leap-seconds.list | tee ./pkg/timeconv/leap-seconds.list | ./src/internal/out/leap-seconds go > ./pkg/timeconv/leap.go",
        "package": "sh -c 'cd src/extensions/${0} && yarn package'",
        "package-all": "yarn package core && yarn package fprime",
        "install-cli": "install -g root -o root out/* /usr/bin",
        "postinstall": "patch-package"
    },
    "dependencies": {
        "@eslint/compat": "^1.1.0",
        "globals": "^15.6.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.20.0",
        "@hyrious/esbuild-plugin-style": "^0.3.5",
        "@jest/globals": "^29.7.0",
        "@types/jest": "^29.5.12",
        "@types/vscode": "^1.99.0",
        "@typescript-eslint/eslint-plugin": "^8.24.0",
        "@typescript-eslint/parser": "^8.24.0",
        "@vscode/test-electron": "^2.2.0",
        "async": "^3.2.4",
        "esbuild": "0.24.0",
        "esbuild-css-modules-plugin": "^3.1.1",
        "esbuild-sass-plugin": "^3.2.0",
        "sass-embedded": "^1.71.1",
        "eslint": "^9.20.1",
        "eslint-formatter-checkstyle": "^8.40.0",
        "jest": "^29.7.0",
        "jest-text-transformer": "^1.0.4",
        "patch-package": "^8.0.0",
        "tmp": "^0.2.1",
        "protobufjs-cli": "^1.1.3",
        "protobufjs": "^7.4.0",
        "ts-jest": "^29.1.2",
        "typescript": "^5.5.2",
        "typescript-eslint": "8.17.0"
    }
}
