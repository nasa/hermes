{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "hermes-uplink",
    "scopeName": "source.uplink",
    "patterns": [
        {
            "include": "#comment"
        },
        {
            "include": "#string"
        },
        {
            "include": "#numeric-literal"
        },
        {
            "include": "#boolean-literal"
        },
        {
            "include": "#command"
        }
    ],
    "repository": {
        "comment": {
            "name": "comment.line.uplink",
            "begin": "@",
            "end": "\n"
        },
        "string": {
            "patterns": [
                {
                    "include": "#qstring-single"
                },
                {
                    "include": "#qstring-double"
                }
            ]
        },
        "qstring-double": {
            "name": "string.quoted.double.uplink",
            "begin": "\"",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.string.begin.uplink"
                }
            },
            "end": "(\")|((?:[^\\\\\\n])$)",
            "endCaptures": {
                "1": {
                    "name": "punctuation.definition.string.end.uplink"
                },
                "2": {
                    "name": "invalid.illegal.newline.uplink"
                }
            },
            "patterns": [
                {
                    "include": "#string-character-escape"
                }
            ]
        },
        "qstring-single": {
            "name": "string.quoted.single.uplink",
            "begin": "'",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.string.begin.uplink"
                }
            },
            "end": "(\\')|((?:[^\\\\\\n])$)",
            "endCaptures": {
                "1": {
                    "name": "punctuation.definition.string.end.uplink"
                },
                "2": {
                    "name": "invalid.illegal.newline.uplink"
                }
            },
            "patterns": [
                {
                    "include": "#string-character-escape"
                }
            ]
        },
        "numeric-literal": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.uplink",
                    "match": "\\b(?<!\\$)0(x|X)[0-9a-fA-F]+\\b(?!\\$)"
                },
                {
                    "name": "constant.numeric.binary.uplink",
                    "match": "\\b(?<!\\$)0(b|B)[01]+\\b(?!\\$)"
                },
                {
                    "name": "constant.numeric.octal.uplink",
                    "match": "\\b(?<!\\$)0(o|O)?[0-7]+\\b(?!\\$)"
                },
                {
                    "match": "(?x)\n(?<!\\$)(?:\n  (?:\\b[0-9]+(\\.)[0-9]+[eE][+-]?[0-9]+\\b)| # 1.1E+3\n  (?:\\b[0-9]+(\\.)[eE][+-]?[0-9]+\\b)|       # 1.E+3\n  (?:\\B(\\.)[0-9]+[eE][+-]?[0-9]+\\b)|       # .1E+3\n  (?:\\b[0-9]+[eE][+-]?[0-9]+\\b)|            # 1E+3\n  (?:\\b[0-9]+(\\.)[0-9]+\\b)|                # 1.1\n  (?:\\b[0-9]+(\\.)\\B)|                      # 1.\n  (?:\\B(\\.)[0-9]+\\b)|                      # .1\n  (?:\\b[0-9]+\\b(?!\\.))                     # 1\n)(?!\\$)",
                    "captures": {
                        "0": {
                            "name": "constant.numeric.decimal.uplink"
                        },
                        "1": {
                            "name": "meta.delimiter.decimal.period.uplink"
                        },
                        "2": {
                            "name": "meta.delimiter.decimal.period.uplink"
                        },
                        "3": {
                            "name": "meta.delimiter.decimal.period.uplink"
                        },
                        "4": {
                            "name": "meta.delimiter.decimal.period.uplink"
                        },
                        "5": {
                            "name": "meta.delimiter.decimal.period.uplink"
                        },
                        "6": {
                            "name": "meta.delimiter.decimal.period.uplink"
                        }
                    }
                }
            ]
        },
        "boolean-literal": {
            "patterns": [
                {
                    "name": "constant.language.boolean.true.uplink",
                    "match": "\\b(?:true|True|TRUE)\\b"
                },
                {
                    "name": "constant.language.boolean.false.uplink",
                    "match": "\\b(?:false|False|FALSE)\\b"
                }
            ]
        },
        "string-character-escape": {
            "name": "constant.character.escape.uplink",
            "match": "\\\\(x\\h{2}|[0-2][0-7]{0,2}|3[0-6][0-7]?|37[0-7]?|[4-7][0-7]?|.|$)"
        },
        "command": {
            "match": "^[\\s]*([A-Za-z_][A-Za-z_0-9-]*)\\b",
            "name": "entity.name.function"
        }
    }
}