enum E_BA U8 {
    OPTION_0 = 0
    OPTION_1 = 1
    OPTION_2 = 2
    OPTION_3 = 3
}

struct BA * {
    bitmask {
        # Read an entire byte
        F1: 3 -> E_BA
        F2: 4
        F3: 1

        # Read more than one byte
        F4: 9

        # Read across two bytes
        F5: 10

        # Reset to multiple of 8
        :5

        # Large read
        F6: 32

        :2
        F7: 57
    }
}

struct S_BA * {
    M: BA
    M3: [3]BA
    MD: [U8]BA
    MDF: [`s.M.F5`]BA
    MF: [*]BA
}
